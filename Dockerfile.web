FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy csproj and restore
COPY ContractManagementSystem-master/*.csproj ./ContractManagementSystem-master/
RUN dotnet restore ./ContractManagementSystem-master/ContractManagementSystem.csproj

# Copy everything else and build
COPY . .
WORKDIR /src/ContractManagementSystem-master
RUN dotnet publish -c Release -o /app/publish

# Runtime image
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
EXPOSE 8080
EXPOSE 8081

ENV ASPNETCORE_ENVIRONMENT=Production
ENV ASPNETCORE_URLS=http://+:8080

COPY --from=build /app/publish .

ENTRYPOINT ["dotnet", "ContractManagementSystem.dll"]
