@model ContractManagementSystem.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<div class="container">
    <h1>Create New Contract</h1>
    <hr />

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="ClientId" class="form-label">Client</label>
                    <select asp-for="ClientId" class="form-select" asp-items="ViewBag.Clients">
                        <option value="">-- Select Client --</option>
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Status" class="form-label">Contract Status</label>
                            <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<ContractManagementSystem.Models.ContractStatus>()"></select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ServiceLevel" class="form-label">Service Level</label>
                            <select asp-for="ServiceLevel" class="form-select" asp-items="Html.GetEnumSelectList<ContractManagementSystem.Models.ServiceLevel>()"></select>
                            <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="signedAgreement" class="form-label">Signed Agreement (PDF only)</label>
                    <input type="file" name="signedAgreement" class="form-control" accept=".pdf" />
                    <div class="form-text">Only PDF files are allowed. Maximum size: 10MB</div>
                    <span id="fileError" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Create Contract
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0">Information</h6>
                </div>
                <div class="card-body">
                    <p><strong>Contract Status Rules:</strong></p>
                    <ul>
                        <li><span class="badge bg-success">Active</span> - Can create service requests</li>
                        <li><span class="badge bg-warning">Draft</span> - Can create service requests</li>
                        <li><span class="badge bg-danger">Expired</span> - Cannot create service requests</li>
                        <li><span class="badge bg-secondary">On Hold</span> - Cannot create service requests</li>
                    </ul>
                    <hr />
                    <p><strong>Supported File Types:</strong></p>
                    <p>Only <strong>PDF</strong> files are accepted for signed agreements.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Client-side file validation
        document.querySelector('input[type="file"]').addEventListener('change', function(e) {
            const file = e.target.files[0];
            const fileError = document.getElementById('fileError');

            if (file) {
                const extension = file.name.split('.').pop().toLowerCase();
                if (extension !== 'pdf') {
                    fileError.textContent = 'Only PDF files are allowed!';
                    this.value = '';
                } else {
                    fileError.textContent = '';
                }
            }
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}