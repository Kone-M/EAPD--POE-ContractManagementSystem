@model ContractManagementSystem.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<style>
    .delete-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
    }

    .warning-box {
        background: #fff3cd;
        border-left: 4px solid #ffc107;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .info-row {
        display: flex;
        padding: 10px 0;
        border-bottom: 1px solid #eee;
    }

    .info-label {
        width: 150px;
        font-weight: bold;
    }

    .info-value {
        flex: 1;
    }
</style>

<div class="delete-container">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="fas fa-exclamation-triangle"></i> Delete Contract
            </h4>
        </div>
        <div class="card-body">
            <div class="warning-box">
                <i class="fas fa-warning"></i>
                <strong>Warning!</strong> Are you sure you want to delete this contract? This action cannot be undone.
            </div>

            @if (Model.ServiceRequests != null && Model.ServiceRequests.Any())
            {
                <div class="alert alert-danger">
                    <i class="fas fa-ban"></i>
                    <strong>Cannot Delete!</strong> This contract has <strong>@Model.ServiceRequests.Count</strong> service request(s).
                    Please delete the service requests first.
                </div>
            }

            <div class="info-row">
                <div class="info-label">Client:</div>
                <div class="info-value">@Model.Client?.Name</div>
            </div>
            <div class="info-row">
                <div class="info-label">Period:</div>
                <div class="info-value">@Model.StartDate.ToString("dd MMM yyyy") to @Model.EndDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="info-row">
                <div class="info-label">Status:</div>
                <div class="info-value">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.Status</span>
                    }
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Service Level:</div>
                <div class="info-value">@Model.ServiceLevel</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.SignedAgreementFileName))
            {
                <div class="info-row">
                    <div class="info-label">Agreement:</div>
                    <div class="info-value">@Model.SignedAgreementFileName</div>
                </div>
            }

            <form asp-action="Delete" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-danger" @(Model.ServiceRequests != null && Model.ServiceRequests.Any() ? "disabled" : "")>
                        <i class="fas fa-trash"></i> Confirm Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>